      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(aegis_entities_detected_total[5m])) by (entity_type)",
          "legendFormat": "{{entity_type}}",
          "refId": "A"
        }
      ],
      "title": "Entités détectées / s par type",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-aegis" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 6,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(aegis_batch_size_bucket[5m])) by (le))",
          "legendFormat": "p99 batch size",
          "refId": "A"
        },
        {
          "expr": "aegis_active_connections",
          "legendFormat": "connexions actives",
          "refId": "B"
        }
      ],
      "title": "Taille des lots (p99) & connexions actives",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 7,
      "title": "NER & alertes (métriques)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-aegis" },
      "fieldConfig": { "defaults": { "unit": "s", "max": 1, "min": 0 } },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 19 },
      "id": 8,
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(aegis_ner_inference_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99 NER",
          "refId": "A"
        }
      ],
      "title": "Latence NER (P99, pipeline L3)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-aegis" },
      "fieldConfig": { "defaults": { "max": 1, "min": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } } },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 19 },
      "id": 9,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "aegis_component_ready", "legendFormat": "{{component}}", "refId": "A" }
      ],
      "title": "Composants prêts (1=OK)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-aegis" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 26 },
      "id": 10,
      "targets": [
        {
          "expr": "sum(rate(aegis_anonymize_operations_total[5m])) by (operator_type)",
          "legendFormat": "{{operator_type}}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(aegis_false_positive_reports_total[5m])) by (channel)",
          "legendFormat": "FP {{channel}}",
          "refId": "B"
        },
        {
          "expr": "sum(rate(aegis_deanonymize_operations_total[5m]))",
          "legendFormat": "deanonymize/s",
          "refId": "C"
        }
      ],
      "title": "Anonymisation / feedback / dé-anonymisation",
      "type": "timeseries"
    }
